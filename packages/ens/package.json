{
  "name": "@brainpedia/ens",
  "version": "0.1.0",
  "description": "ENS subname registrar, text records, and access-token subnames for Brainpedia. Fully config-driven — no hardcoded addresses or names.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@ensdomains/ensjs": "^4.0.2",
    "viem": "^2.21.55"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
