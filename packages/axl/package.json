{
  "name": "@brainpedia/axl",
  "version": "0.1.0",
  "description": "Client + orchestrator for Gensyn's Agent Exchange Layer (AXL) — encrypted P2P MCP/A2A routing between Brain nodes.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@brainpedia/ens": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
