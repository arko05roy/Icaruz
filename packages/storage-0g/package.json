{
  "name": "@brainpedia/storage-0g",
  "version": "0.1.0",
  "description": "0G Storage wrappers — KV (live wiki) + Log (snapshot manifests + merkle roots).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@0glabs/0g-ts-sdk": "^0.3.3",
    "ethers": "^6.13.4",
    "viem": "^2.21.55"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
