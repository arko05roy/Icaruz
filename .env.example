# =============================================================================
# Brainpedia — environment configuration
# Copy to .env (gitignored) and fill in. NEVER commit .env files.
# =============================================================================

# -----------------------------------------------------------------------------
# 0G Chain / Storage / Compute (mainnet 16661 — Aristotle)
# Switch ZG_NETWORK to "testnet" to fall back to the Galileo testnet block below.
# -----------------------------------------------------------------------------
ZG_NETWORK=mainnet

# Mainnet (Aristotle, chainId 16661)
ZG_RPC_URL=https://evmrpc.0g.ai
ZG_CHAIN_ID=16661
ZG_FLOW_CONTRACT_ADDRESS=0x62D4144dB0F0a6fBBaeb6296c785C71B3D57C526
ZG_STORAGE_INDEXER_URL=https://indexer-storage-turbo.0g.ai
ZG_STORAGE_START_BLOCK=2387557
ZG_EXPLORER_URL=https://chainscan.0g.ai

# 0G Compute mainnet contracts
ZG_COMPUTE_LEDGER_ADDRESS=0x2dE54c845Cd948B72D2e32e39586fe89607074E3
ZG_COMPUTE_INFERENCE_ADDRESS=0x47340d900bdFec2BD393c626E12ea0656F938d84
ZG_COMPUTE_FINE_TUNING_ADDRESS=0x4e3474095518883744ddf135b7E0A23301c7F9c0

# Testnet fallback (Galileo, chainId 16602) — set ZG_NETWORK=testnet to use these.
ZG_RPC_URL_TESTNET=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID_TESTNET=16602
ZG_FLOW_CONTRACT_ADDRESS_TESTNET=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296
ZG_STORAGE_INDEXER_URL_TESTNET=https://indexer-storage-testnet-turbo.0g.ai
ZG_EXPLORER_URL_TESTNET=https://chainscan-galileo.0g.ai

# Deployed by us — set after running `forge script script/Deploy.s.sol --rpc-url $ZG_RPC_URL`
ZG_INFT_CONTRACT_ADDRESS=
ZG_BRAIN_MINTER_ADDRESS=
ZG_ROYALTY_DISTRIBUTOR_ADDRESS=
ZG_BRAIN_ORACLE_ADDRESS=

# 0G Compute inference provider — set after `broker.inference.listService()` returns one
ZG_COMPUTE_PROVIDER_ADDRESS=
ZG_COMPUTE_PROVIDER_URL=
ZG_COMPUTE_MODEL=

# Wallet that signs storage uploads, broker deposits, iNFT mints.
# DO NOT COMMIT. Use a dev wallet only.
ZG_WALLET_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# ENS — discovery & access tokens
# Per Brainpedia bounty: NO HARDCODED VALUES. All config flows through here.
# -----------------------------------------------------------------------------
# Network: "sepolia" or "mainnet". ENS contract addresses are resolved
# from @ensdomains/ensjs based on this — never hardcoded in source.
ENS_NETWORK=sepolia

# Parent name we own and issue subnames under.
# Used for: <name>.brainpedia.eth, agent<hash>.client.brainpedia.eth,
#          <topic>.discover.brainpedia.eth
ENS_PARENT_NAME=brainpedia.eth

# Subname registrar contracts we deploy (Brain owners + access tokens).
# Set after deploying contracts/src/SubnameRegistrar.sol +
#                  contracts/src/AccessTokenRegistrar.sol
ENS_SUBNAME_REGISTRAR_ADDRESS=
ENS_ACCESS_TOKEN_REGISTRAR_ADDRESS=

# Default access-token TTL in seconds (one-time-use subnames).
ENS_ACCESS_TOKEN_TTL_SECONDS=900

# RPC for ENS reads/writes. Use Alchemy/Infura/your own node.
ENS_RPC_URL=

# -----------------------------------------------------------------------------
# AXL (Gensyn Agent Exchange Layer)
# -----------------------------------------------------------------------------
# Local AXL node HTTP API. Each Brain runs its own daemon on its own port.
AXL_API_URL=http://127.0.0.1:9002

# Path to the local AXL node config (contains Ed25519 private key — gitignored)
AXL_NODE_CONFIG_PATH=./axl-node-config.json

# Bootstrap peers (TLS-prefixed addresses of public AXL nodes we run).
# Comma-separated. Brains connect through these to find each other.
AXL_BOOTSTRAP_PEERS=

# -----------------------------------------------------------------------------
# BTL Runtime (hackathon mode — inference gateway)
# https://runtime.badtheorylabs.com/docs
# -----------------------------------------------------------------------------
GATEWAY_API_KEY=
BTL_RUNTIME_BASE_URL=https://api.badtheorylabs.com/v1
# Cheap model for topic routing; query model for brain Q&A + synthesis
BTL_QUERY_MODEL=btl-2
BTL_ROUTER_MODEL=btl-2

# Brain runtime (in-process inside Next.js — no separate brain service)
BRAIN_ENS_NAME=yudhi.bpedia.eth
BRAIN_STORAGE_ROOT=
BRAIN_SPECIALTY=EVM security, audit methodology, incident post-mortems
# Optional legacy fallback to external brain HTTP service (apps/brain :7100)
# BRAINPEDIA_BRAIN_URL=http://127.0.0.1:7100

# Optional per-brain storage roots for multi-tenant local targets
# LOCAL_BRAIN_ROOTS_JSON={"yudhi":"0x...","karpathy":"0x..."}

# Skip ENS access tokens in BTL demo (mixture passes accessToken=btl-hackathon)
BRAIN_ENFORCE_ACCESS_TOKENS=false

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# -----------------------------------------------------------------------------
# MCP server (apps/mcp-server) — invoked by Claude Desktop
# -----------------------------------------------------------------------------
# Default vault path used when the user does not pass one explicitly
BRAINPEDIA_DEFAULT_VAULT_PATH=
